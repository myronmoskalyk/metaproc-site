---
import PageLayout from '../layouts/PageLayout.astro';
import ProofAsset from '../components/ProofAsset.astro';
import { getImage } from 'astro:assets';

// Real captures from the live containerized app (Stage 4).
import demoVideo from '../assets/proof/demo.webm';
import demoPosterPng from '../assets/proof/demo-poster.png';
import shotWorkflowStore from '../assets/proof/workflow-store.png';
import shotPlotsStudio from '../assets/proof/plots-studio.png';
import shotReportBuilder from '../assets/proof/report-builder.png';
import shotGradeSof from '../assets/proof/grade-sof.png';
import shotCodePanel from '../assets/proof/code-panel.png';

// Poster frame (extracted from demo.webm at 12 s) — optimized to WebP at build.
// 960w keeps the LCP request small (~30 kB); it's swapped out the moment playback starts.
const demoPoster = await getImage({ src: demoPosterPng, width: 960, format: 'webp' });

// Full-width sizes for screenshots inside the 48rem prose column.
const SHOT_SIZES = '(min-width: 52rem) 48rem, 92vw';
const SHOT_WIDTHS = [480, 800, 1200, 1600];

const groups = [
	{
		title: 'Import & prepare',
		blurb: 'Get messy real-world extraction workbooks into shape — without leaving the browser.',
		shots: [],
		more: [
			{ label: 'Data import', caption: 'CSV / Excel upload, multi-sheet workbooks, automatic header detection, value boxes.' },
			{ label: 'Edit & clean', caption: 'Editable grid, per-column retype/rename, row include/exclude — each emitting its exact R.' },
			{ label: 'Combine', caption: 'Join or stack worksheets with auto-detected keys, a grain guard, and fan-out warnings.' },
			{ label: 'Quality checks', caption: 'Duplicate study-ID detection, biological-range checks, configurable consistency rules.' },
		],
	},
	{
		title: 'Explore & analyze',
		blurb: 'Eleven templates, a six-view EDA, network meta-analysis, and a drag-to-build pipeline.',
		shots: [
			{
				image: shotPlotsStudio,
				alt: 'Plots studio: a ten-study forest plot of risk ratios with a random-effects pooled estimate of 0.69 (0.62 to 0.78), plot-type and drawing-engine controls (native metafor or ggplot2) on the left, and a Reproducible R panel underneath labelled "the exact code that drew the preview".',
				caption: 'Plots studio — forest & funnel plots with prediction intervals, re-drawn from your saved analysis and verified against its snapshot. The exact R that drew the preview sits right below.',
			},
			{
				image: shotCodePanel,
				alt: 'Live R code panel beside its raw output: a metafor script — library(metafor), escalc effect-size computation, an rma REML model, forest() and funnel() calls — next to the printed random-effects model results with tau-squared, I-squared and the Q test.',
				caption: 'Every analysis shows the exact R code it ran — metafor calls included — next to the raw model output it produced. Copy it, audit it, re-run it.',
			},
			{
				image: shotWorkflowStore,
				alt: 'The Workflow panel open over the home screen, holding a saved risk-ratio analysis card with buttons to send it to the Plots studio or the Report, and a note that it is saved with your project.',
				caption: 'The workflow store collects results across tabs — reorder them, send them to the Plots studio or the Report, and they persist with your saved project.',
			},
		],
		more: [
			{ label: 'EDA studio', caption: 'Summary, distributions, missingness, correlations, by-group, and scatter — each with code.' },
			{ label: 'Templates', caption: 'Binary, continuous, proportion, correlation, HR, IRR, three-level and more.' },
			{ label: 'Network MA', caption: 'netmeta network plot, league table, P-scores, and net-split inconsistency.' },
			{ label: 'Pipeline', caption: 'Drag components — meta-regression, cumulative, trim-and-fill, Baujat — into an ordered run.' },
		],
	},
	{
		title: 'Appraise & report',
		blurb: 'Risk of bias, GRADE, SWiM, PRISMA, and a reproducibility bundle that re-runs anywhere.',
		shots: [
			{
				image: shotGradeSof,
				alt: 'GRADE certainty-of-evidence form: study design and outcome fields, the five downgrade domains — risk of bias, inconsistency, indirectness, imprecision, publication bias — and a "suggested from your analysis" box citing the observed I-squared and confidence interval.',
				caption: 'GRADE — rate certainty across the five domains, with suggestions pre-filled from your live analysis, feeding a Cochrane-style summary-of-findings row.',
			},
			{
				image: shotReportBuilder,
				alt: 'Reproducible report builder: title and author fields, include-section checkboxes (methods, PRISMA flow, included studies, pooled result, forest plot, heterogeneity, reproducible code, packages used), HTML / PDF / R Markdown output formats, and a reproducibility-bundle download button.',
				caption: 'Report builder — choose sections, generate HTML / PDF / .Rmd, or download the reproducibility bundle: a .zip with the exact analysis script, your data, sessionInfo() and renv.lock.',
			},
		],
		more: [
			{ label: 'Risk of bias', caption: 'RoB 2 / ROBINS-I / QUADAS-2 traffic-light and summary plots (robvis).' },
			{ label: 'SWiM & PRISMA', caption: 'Vote-counting harvest plot and a PRISMA 2020 flow diagram from your screening data.' },
			{ label: 'Reproducibility bundle', caption: 'A .zip with runnable analysis.R, the data, sessionInfo(), and renv.lock.' },
			{ label: 'Tools', caption: 'Effect-size converter (12 conversions) and a-priori power analysis.' },
		],
	},
];
---
<PageLayout
	title="Features"
	activePath="/features"
	lede="A button-driven, template-based workflow that covers the whole meta-analysis — from a raw extraction workbook to a GRADE summary of findings and a re-runnable bundle."
	description="The full MetaProc feature tour: import, clean, analyze, appraise, and report — with the exact R code captured at every step."
>
	{/* The demo poster is the LCP element on this page — fetch it early and hot. */}
	<link slot="head" rel="preload" as="image" href={demoPoster.src} fetchpriority="high" />

	<section class="demo" id="demo" aria-labelledby="demo-title">
		<h2 id="demo-title">Watch it run — 73 seconds</h2>
		<p class="demo__blurb">
			A silent screen capture from the live app: the pairwise binary-outcome template
			loads a worked example, pools ten trials (risk ratio 0.69, I² 0%), gets a GRADE
			certainty rating, and ends at the report builder and the re-drawn forest plot.
			Captions describe each step.
		</p>
		<!-- MP4 fallback deferred — add H.264 encode at Stage 8 with full ffmpeg -->
		<video controls preload="none" width="1600" height="1000" poster={demoPoster.src}>
			<source src={demoVideo} type="video/webm" />
			<track kind="captions" src="/media/demo-captions.vtt" srclang="en" label="English" default />
			Your browser can't play WebM video — the <a href="/docs/quickstart">Quickstart</a>
			walks through the same steps with screenshots.
		</video>
	</section>

	{groups.map((g) => (
		<section class="ftour">
			<h2>{g.title}</h2>
			<p class="ftour__blurb">{g.blurb}</p>
			{g.shots.length > 0 && (
				<div class="ftour__shots">
					{g.shots.map((s) => (
						<ProofAsset
							image={s.image}
							alt={s.alt}
							caption={s.caption}
							sizes={SHOT_SIZES}
							widths={SHOT_WIDTHS}
						/>
					))}
				</div>
			)}
			<ul class="ftour__list">
				{g.more.map((m) => (
					<li><strong>{m.label}.</strong> {m.caption}</li>
				))}
			</ul>
		</section>
	))}

	<p style="margin-top:2rem">
		Every screenshot and the demo above are real captures from the live app (June 2026
		beta) — nothing is mocked up. For the exact, up-to-date capability inventory, see
		the <a href="/docs/manual">generated product manual</a>.
	</p>
</PageLayout>

<style>
	.demo {
		margin-bottom: 3rem;
		scroll-margin-top: 5.5rem; /* clear the sticky header when arriving at /features#demo */
	}
	.demo h2 { margin: 0 0 0.25rem; }
	.demo__blurb { color: var(--mp-muted); margin: 0 0 1.25rem; }
	.demo video {
		display: block;
		width: 100%;
		height: auto;
		border: 1px solid var(--mp-card-border);
		border-radius: var(--mp-radius-lg);
		background: #1e1b2e;
	}

	.ftour { margin-bottom: 3rem; }
	.ftour h2 { margin-bottom: 0.25rem; }
	.ftour__blurb { color: var(--mp-muted); margin: 0 0 1.25rem; }
	.ftour__shots {
		display: grid;
		gap: 2rem;
		margin-bottom: 1.5rem;
	}
	.ftour__list {
		margin: 0;
		padding-left: 1.2rem;
		display: grid;
		gap: 0.5rem;
	}
	.ftour__list li { color: var(--mp-muted); }
	.ftour__list strong { color: var(--mp-ink); }
</style>
