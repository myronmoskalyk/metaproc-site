---
import PageLayout from '../layouts/PageLayout.astro';

// Stub — fuller history will be generated from release tags at Stage 8.
const releases = [
	{
		version: 'v0.2.x',
		label: 'Beta',
		highlights: [
			'Eleven analysis templates, from pairwise binary/continuous to three-level, HR, and IRR.',
			'Network meta-analysis (netmeta): network plot, league table, P-scores, net-split.',
			'Reproducibility bundle — runnable analysis.R + data + sessionInfo() + renv.lock.',
			'GRADE summary-of-findings row populated from the live analysis.',
			'Real-world data robustness: combine grain guard, multi-arm handling, biological-range and consistency checks.',
			'Resolved licensing: metaproc is now GPL-3.0-or-later (2026-06-11).',
		],
	},
];
---
<PageLayout
	title="Changelog"
	activePath="/changelog"
	lede="What is new in MetaProc. This is an early stub — a fuller, tag-driven history arrives with the public release."
	description="MetaProc changelog — release highlights for the current beta."
>
	{releases.map((r) => (
		<section class="rel">
			<h2>{r.version} <span class="rel__label">{r.label}</span></h2>
			<ul>
				{r.highlights.map((h) => <li>{h}</li>)}
			</ul>
		</section>
	))}
</PageLayout>

<style>
	.rel { margin-bottom: 2rem; }
	.rel__label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: #fff;
		background: var(--mp-violet);
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
		vertical-align: middle;
		margin-left: 0.5rem;
	}
</style>
