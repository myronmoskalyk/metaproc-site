---
import BaseLayout from '../layouts/BaseLayout.astro';
import ForestPlot from '../components/ForestPlot.astro';
import ProofAsset from '../components/ProofAsset.astro';

// Real screenshots from the live containerized app (Stage 4 captures).
// NOTE: these still show the violet-era UI — stale since the Orbital retheme;
// recapture is pending (handled by a later stage once the app is restyled).
import shotAppOverview from '../assets/proof/hero-app-overview.png';
import shotWorkflowStore from '../assets/proof/workflow-store.png';
import shotPlotsStudio from '../assets/proof/plots-studio.png';
import shotReportBuilder from '../assets/proof/report-builder.png';
import shotGradeSof from '../assets/proof/grade-sof.png';
import shotCodePanel from '../assets/proof/code-panel.png';

const steps = [
	{
		n: '1',
		title: 'Import',
		body: 'Upload a CSV or Excel workbook — or load a bundled example. MetaProc detects headers, flags duplicate study IDs, and runs biological-range and consistency checks as you go.',
	},
	{
		n: '2',
		title: 'Analyze',
		body: 'Pick a template (binary, continuous, proportion, correlation, time-to-event and more), map your columns, and run. Forest and funnel plots, heterogeneity, subgroups, and sensitivity analyses appear instantly.',
	},
	{
		n: '3',
		title: 'Report',
		body: 'Build a reproducible report (HTML, PDF, or .Rmd), add a GRADE summary of findings, and export a bundle that re-runs in a clean R session and reproduces your pooled estimate.',
	},
];

const tour = [
	{
		image: shotWorkflowStore,
		alt: 'MetaProc home screen with the Workflow panel open on the right, holding a saved risk-ratio analysis with buttons to send it to the Plots studio or the Report.',
		caption: 'Workflow store — every result you collect across tabs, reorderable and sendable to Plots or Report, saved with your project.',
	},
	{
		image: shotPlotsStudio,
		alt: 'Plots studio: a ten-study forest plot of risk ratios with a random-effects pooled estimate of 0.69, plot-type and drawing-engine controls on the left, and a Reproducible R panel underneath.',
		caption: 'Plots studio — forest & funnel plots re-drawn from your saved analysis, with the exact R that drew the preview shown beneath.',
	},
	{
		image: shotReportBuilder,
		alt: 'Reproducible report builder with checkboxes for methods, PRISMA flow, included studies, pooled result, forest plot, heterogeneity, reproducible code and packages used, plus HTML, PDF and R Markdown output formats.',
		caption: 'Report builder — choose sections, export HTML / PDF / .Rmd, or download a reproducibility bundle that re-runs anywhere.',
	},
	{
		image: shotGradeSof,
		alt: 'GRADE certainty-of-evidence form with the five downgrade domains — risk of bias, inconsistency, indirectness, imprecision, publication bias — and suggestions derived from the live analysis.',
		caption: 'GRADE — rate certainty across the five domains, with suggestions pre-filled from your own analysis.',
	},
	{
		image: shotCodePanel,
		alt: 'Live R code panel: a metafor script with escalc effect-size, rma model, forest and funnel calls beside the raw random-effects model output it produced.',
		caption: 'Live R code panel — every analysis shows the exact R it ran, metafor calls included. Copy it, audit it, re-run it.',
	},
];

const audiences = [
	{
		title: 'Clinical researchers',
		body: 'Run a defensible pairwise or network meta-analysis without writing R. RoB 2 / ROBINS-I / QUADAS-2, GRADE, and PRISMA flow are built in.',
	},
	{
		title: 'Students & educators',
		body: 'Learn by doing: guided tour, one-click worked examples, and a plain-language interpretation on every result. The generated R is a teaching tool in itself.',
	},
	{
		title: 'Methodologists',
		body: 'Three-level models, cluster-robust SEs, meta-regression, trim-and-fill, leave-one-out and influence diagnostics — with the exact code captured for every step.',
	},
];

const faqs = [
	{
		q: 'Is it free?',
		a: 'Free while in beta. We will give plenty of notice and a fair offer before anything changes.',
	},
	{
		q: 'Is my data private?',
		a: 'Analyses run in ephemeral, RAM-backed isolated containers hosted in the EU and destroyed at the end of your session. Please do not upload patient-level identifiable data — MetaProc works on the aggregate, study-level data a meta-analysis needs.',
	},
	{
		q: 'Can I see the code my analysis ran?',
		a: 'Yes — that is the whole point. Every model, table, and figure is produced by building R code from your choices, running that exact code, and showing you the same text in a copyable panel. What you see is what ran.',
	},
	{
		q: 'Web or desktop?',
		a: 'The browser app needs nothing installed and is always current. A desktop build (bundling R and all packages for fully-offline use) is planned. See the web-vs-desktop comparison in the docs.',
	},
	{
		q: 'How do I cite it?',
		a: 'A citation and the exact package versions ship in every report and reproducibility bundle (via sessionInfo() and renv.lock), so your write-up names metaproc and the underlying engines — metafor, netmeta and friends — with the versions you actually used.',
	},
	{
		q: 'What is the license?',
		a: 'The code is GPL-3.0-or-later (built on the GPL R meta-analysis ecosystem). The name "MetaProc" is a trademark. See the license page for the plain-language version.',
	},
];
---
<BaseLayout title="MetaProc" activePath="/">
	<!-- ===================== HERO ===================== -->
	<section class="hero">
		<div class="mp-container hero__grid">
			<div class="hero__copy mp-rise">
				<p class="mp-eyebrow">Reproducible meta-analysis</p>
				<h1 class="mp-shine">Run a complete, reproducible meta-analysis in your browser.</h1>
				<p class="hero__sub">
					Data to forest plot to GRADE summary — with the exact R code for every step.
				</p>
				<div class="hero__cta">
					<a class="mp-cta" href="#" data-placeholder="app-url">Launch MetaProc free</a>
					<a class="hero__secondary" href="/download">Prefer the desktop app?</a>
				</div>
			</div>
			<div class="hero__visual mp-rise" style="--mp-rise-delay:.1s">
				<!-- CSS-only miniature of the launch-core ring (breathe + spin, no comet) -->
				<div class="hero__core" aria-hidden="true">
					<span class="hero__halo hero__halo--bloom"></span>
					<span class="hero__halo"></span>
					<span class="hero__dashring"></span>
				</div>
				<div class="hero__panel mp-panel">
					<ForestPlot />
				</div>
			</div>
		</div>
	</section>

	<!-- ===================== HOW IT WORKS ===================== -->
	<section class="section" aria-labelledby="how">
		<div class="mp-container">
			<h2 id="how" class="section__title">How it works</h2>
			<ol class="steps">
				{steps.map((s) => (
					<li class="step mp-panel mp-panel--bracket mp-panel--lift">
						<span class="step__n" aria-hidden="true">{s.n}</span>
						<h3>{s.title}</h3>
						<p>{s.body}</p>
					</li>
				))}
			</ol>
			<div class="how__shot">
				<ProofAsset
					image={shotAppOverview}
					alt="MetaProc home screen: a welcome banner with Start: import your data and Plan my analysis buttons, above a five-step Your workflow strip — import data, explore (EDA), run an analysis, plan a pipeline, build a report."
					caption="The home screen mirrors those steps — import, explore, analyze, pipeline, report — and your whole project saves to a file you can reload later."
					sizes="(min-width: 78rem) 72rem, 96vw"
					widths={[800, 1200, 1600, 2000]}
				/>
			</div>
		</div>
	</section>

	<!-- ===================== FEATURE TOUR ===================== -->
	<section class="section section--tint" aria-labelledby="tour">
		<div class="mp-container">
			<h2 id="tour" class="section__title">A tour of the workspace</h2>
			<p class="section__lead">
				Every surface in MetaProc — from the workflow store to the live R code panel.
			</p>
			<div class="tour__grid">
				{tour.map((t) => (
					<ProofAsset image={t.image} alt={t.alt} caption={t.caption} />
				))}
			</div>
			<p class="section__more"><a href="/features">See the full feature tour →</a></p>
		</div>
	</section>

	<!-- ===================== DEMO TEASER ===================== -->
	<section class="section demo-teaser" aria-labelledby="demo-teaser-title">
		<div class="mp-container demo-teaser__inner">
			<div>
				<h2 id="demo-teaser-title" class="section__title">See it run</h2>
				<p>
					A 73-second screen capture from the live app: a worked binary-outcome example
					pools ten trials, gets a GRADE rating, and exports a reproducible report.
				</p>
			</div>
			<a class="mp-cta mp-cta--outline" href="/features#demo">
				<svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true" fill="currentColor"><path d="M4 2.5v11l9-5.5-9-5.5z"/></svg>
				Watch the demo
			</a>
		</div>
	</section>

	<!-- ===================== AUDIENCE CARDS ===================== -->
	<section class="section" aria-labelledby="who">
		<div class="mp-container">
			<h2 id="who" class="section__title">Built for the people who do the work</h2>
			<div class="cards">
				{audiences.map((a) => (
					<article class="card mp-panel mp-panel--bracket mp-panel--lift">
						<h3>{a.title}</h3>
						<p>{a.body}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- ===================== METHODS ===================== -->
	<section class="section section--code" aria-labelledby="methods">
		<div class="mp-container methods">
			<div>
				<h2 id="methods" class="section__title section__title--light">Methods you can defend</h2>
				<p class="methods__lead">
					MetaProc does not reinvent the statistics. It drives the same gold-standard R
					engines the field already trusts, and it is golden-tested against them: a suite
					of <strong>2,600+ automated tests</strong> checks that every result matches the
					reference engine, byte for byte.
				</p>
				<a class="mp-cta mp-cta--light" href="/methods">How we validate</a>
			</div>
			<ul class="engines" aria-label="Underlying engines">
				<li>metafor</li>
				<li>netmeta</li>
				<li>meta</li>
				<li>robvis</li>
				<li>esc</li>
			</ul>
		</div>
	</section>

	<!-- ===================== DOCS TEASER ===================== -->
	<section class="section" aria-labelledby="docs-teaser">
		<div class="mp-container docs-teaser">
			<div>
				<h2 id="docs-teaser" class="section__title">Read the docs</h2>
				<p>
					New to meta-analysis or new to MetaProc? The Quickstart walks you from a blank
					workspace to a finished forest plot, GRADE summary, and exported report in about
					ten minutes.
				</p>
			</div>
			<a class="mp-cta mp-cta--outline" href="/docs/quickstart">Open the Quickstart</a>
		</div>
	</section>

	<!-- ===================== FAQ ===================== -->
	<section class="section section--tint" id="faq" aria-labelledby="faq-title">
		<div class="mp-container faq">
			<h2 id="faq-title" class="section__title">Frequently asked</h2>
			<div class="faq__list">
				{faqs.map((f) => (
					<details class="faq__item">
						<summary>{f.q}</summary>
						<div class="faq__answer"><p>{f.a}</p></div>
					</details>
				))}
			</div>
		</div>
	</section>

	<!-- ===================== FINAL CTA ===================== -->
	<section class="section final-cta" aria-labelledby="final">
		<div class="mp-container">
			<h2 id="final">Your next meta-analysis starts in the browser.</h2>
			<a class="mp-cta mp-cta--lg" href="#" data-placeholder="app-url">Launch MetaProc free</a>
		</div>
	</section>
</BaseLayout>

<style>
	/* Hero — transparent over the aurora canvas; rise entrance + shine heading. */
	.hero {
		padding-block: clamp(2.5rem, 6vw, 5rem);
		border-bottom: 1px solid var(--mp-hair);
	}
	.hero__grid {
		display: grid;
		grid-template-columns: 1.05fr 1fr;
		gap: clamp(2rem, 5vw, 4rem);
		align-items: center;
	}
	.hero h1 {
		font-size: clamp(2rem, 4.5vw, 3.2rem);
		line-height: 1.08;
		letter-spacing: -0.03em;
		font-weight: 850;
		margin: 0 0 1rem;
	}
	.hero__sub {
		font-size: clamp(1.05rem, 2vw, 1.3rem);
		color: var(--mp-muted);
		margin: 0 0 2rem;
		max-width: 32rem;
	}
	.hero__cta {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}
	.hero__secondary {
		font-weight: 600;
		color: var(--mp-link);
		text-decoration: none;
	}
	.hero__secondary:hover { text-decoration: underline; }

	.hero__visual {
		position: relative;
	}
	.hero__panel {
		position: relative;
		z-index: 1;
		padding: 1.25rem 1.5rem;
	}

	/* Launch-core miniature: conic halo ring (spin) inside a breathing wrapper,
	   plus a counter-rotating dashed accent ring. CSS-only, transform/opacity. */
	.hero__core {
		position: absolute;
		top: -3.5rem;
		right: -3rem;
		width: 240px;
		height: 240px;
		display: grid;
		place-items: center;
		pointer-events: none;
		animation: mp-ringbreathe 5.5s ease-in-out infinite;
		will-change: transform;
	}
	.hero__halo {
		grid-area: 1 / 1;
		width: 190px;
		height: 190px;
		border-radius: 50%;
		background: conic-gradient(from 0deg, var(--mp-g1), var(--mp-g2), var(--mp-g1), var(--mp-g2), var(--mp-g1));
		-webkit-mask: radial-gradient(closest-side, transparent 0 80%, #000 81% 100%);
		mask: radial-gradient(closest-side, transparent 0 80%, #000 81% 100%);
		opacity: .8;
		animation: mp-spin 16s linear infinite;
		will-change: transform;
	}
	.hero__halo--bloom {
		filter: blur(12px) saturate(1.2);
		opacity: .4;
	}
	.hero__dashring {
		grid-area: 1 / 1;
		width: 232px;
		height: 232px;
		border-radius: 50%;
		border: 1.5px dashed color-mix(in srgb, var(--mp-accent2) 42%, transparent);
		animation: mp-spin 44s linear infinite reverse;
		will-change: transform;
	}

	@media (max-width: 820px) {
		.hero__grid { grid-template-columns: 1fr; }
		.hero__core { right: -1.5rem; top: -2.5rem; transform: scale(.8); }
	}

	/* Generic section scaffolding */
	.section { padding-block: clamp(3rem, 6vw, 5rem); }
	.section--tint {
		background: var(--mp-tint);
		border-block: 1px solid var(--mp-hair);
	}
	/* Dark "code anchor" band — stays dusk in BOTH moods (BRAND §3). */
	.section--code {
		background:
			radial-gradient(60% 90% at 85% 10%, color-mix(in srgb, var(--mp-g2) 12%, transparent), transparent 60%),
			linear-gradient(135deg, #0D141B 0%, #101A22 100%);
		border-block: 1px solid var(--mp-code-edge);
	}
	.section__title {
		font-size: clamp(1.6rem, 3vw, 2.2rem);
		letter-spacing: -0.01em;
		margin: 0 0 0.5rem;
	}
	.section__title--light { color: #EEF4FB; }
	.section__lead, .section__more { color: var(--mp-muted); }
	.section__lead { margin: 0 0 2rem; font-size: 1.05rem; }
	.section__more { margin-top: 1.5rem; }
	.section__more a { color: var(--mp-link); font-weight: 600; text-decoration: none; }
	.section__more a:hover { text-decoration: underline; }

	/* Steps */
	.steps {
		list-style: none;
		margin: 1.5rem 0 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		counter-reset: step;
	}
	.step {
		padding: 1.5rem;
	}
	.step__n {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 2.2rem;
		border-radius: 50%;
		background: var(--mp-grad-cta);
		box-shadow: 0 0 18px -6px var(--mp-glow);
		color: #fff;
		font-weight: 800;
		margin-bottom: 0.75rem;
	}
	.step h3 { margin: 0 0 0.4rem; font-size: 1.25rem; }
	.step p { margin: 0; color: var(--mp-muted); }

	/* App overview shot under How-it-works */
	.how__shot {
		margin-top: 2rem;
	}

	/* Feature tour grid */
	.tour__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr));
		gap: 1.75rem;
	}

	/* Demo teaser */
	.demo-teaser {
		padding-block: clamp(2rem, 4vw, 3rem);
		border-block: 1px solid var(--mp-hair);
	}
	.demo-teaser__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		flex-wrap: wrap;
	}
	.demo-teaser p {
		color: var(--mp-muted);
		max-width: 38rem;
		margin: 0.5rem 0 0;
	}

	/* Audience cards */
	.cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		margin-top: 1.5rem;
	}
	.card {
		padding: 1.5rem;
	}
	.card h3 { margin: 0 0 0.5rem; font-size: 1.2rem; }
	.card p { margin: 0; color: var(--mp-muted); }

	/* Methods (dark code anchor) */
	.methods {
		display: grid;
		grid-template-columns: 1.6fr 1fr;
		gap: 2.5rem;
		align-items: center;
	}
	.methods__lead { color: #9DB0C3; font-size: 1.1rem; margin: 0 0 1.5rem; }
	.methods__lead strong { color: #EEF4FB; }
	.engines {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
	.engines li {
		font-family: var(--font-mono, monospace);
		font-size: 0.95rem;
		color: var(--mp-code-fg);
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid var(--mp-code-edge);
		border-radius: var(--mp-radius);
		padding: 0.5rem 0.9rem;
	}

	/* Docs teaser */
	.docs-teaser {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		flex-wrap: wrap;
	}
	.docs-teaser p { color: var(--mp-muted); max-width: 38rem; margin: 0.5rem 0 0; }

	/* FAQ */
	.faq__list {
		margin-top: 1.5rem;
		display: grid;
		gap: 0.75rem;
		max-width: 50rem;
	}
	.faq__item {
		background: var(--mp-panel);
		border: 1px solid var(--mp-edge);
		border-radius: var(--mp-radius);
		padding: 0 1.25rem;
		transition: border-color .15s ease;
	}
	.faq__item:hover { border-color: color-mix(in srgb, var(--mp-brand) 44%, var(--mp-edge)); }
	.faq__item summary {
		cursor: pointer;
		font-weight: 600;
		padding: 1rem 0;
		list-style: none;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.faq__item summary::after {
		content: '+';
		font-size: 1.3rem;
		color: var(--mp-accent-deep);
		margin-left: 1rem;
	}
	.faq__item[open] summary::after { content: '\2212'; }
	.faq__answer { padding-bottom: 1rem; }
	.faq__answer p { margin: 0; color: var(--mp-muted); }

	/* Final CTA */
	.final-cta { text-align: center; }
	.final-cta h2 {
		font-size: clamp(1.7rem, 3.5vw, 2.4rem);
		margin: 0 0 1.5rem;
	}

	@media (max-width: 820px) {
		.steps, .cards { grid-template-columns: 1fr; }
		.methods { grid-template-columns: 1fr; }
	}
</style>
