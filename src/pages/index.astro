---
import BaseLayout from '../layouts/BaseLayout.astro';
import ForestPlot from '../components/ForestPlot.astro';
import ProofAsset from '../components/ProofAsset.astro';

// Real screenshots from the live Orbital app (recaptured 2026-06-13 from the
// native app on 127.0.0.1:7991, teal/amber Orbital UI, not the old violet era).
import shotAppOverview from '../assets/proof/hero-app-overview.png';
import shotWorkflowStore from '../assets/proof/workflow-store.png';
import shotPlotsStudio from '../assets/proof/plots-studio.png';
import shotReportBuilder from '../assets/proof/report-builder.png';
import shotGradeSof from '../assets/proof/grade-sof.png';
import shotCodePanel from '../assets/proof/code-panel.png';

const steps = [
	{
		n: '1',
		title: 'Import',
		body: 'Upload a CSV or Excel workbook, or load a bundled example. MetaProc detects headers, flags duplicate study IDs, and runs biological-range and consistency checks as you go.',
	},
	{
		n: '2',
		title: 'Analyze',
		body: 'Pick a template (binary, continuous, proportion, correlation, time-to-event and more), map your columns, and run. Forest and funnel plots, heterogeneity, subgroups, and sensitivity analyses appear instantly.',
	},
	{
		n: '3',
		title: 'Report',
		body: 'Build a reproducible report (HTML, PDF, or .Rmd), add a GRADE summary of findings, and export a bundle that re-runs in a clean R session and reproduces your pooled estimate.',
	},
];

// Bento tour: the code panel leads as a wide feature tile (it carries the
// product's whole thesis), the rest fall into a rhythmic asymmetric grid.
const tour = [
	{
		image: shotCodePanel,
		alt: 'Live R code panel: a metafor script with escalc effect-size, rma model, forest and funnel calls beside the raw random-effects model output it produced.',
		title: 'Live R code panel',
		caption: 'Every analysis shows the exact R it ran, metafor calls included. Copy it, audit it, re-run it.',
		feature: true,
	},
	{
		image: shotWorkflowStore,
		alt: 'MetaProc home screen with the Workflow panel open on the right, holding a saved risk-ratio analysis with buttons to send it to the Plots studio or the Report.',
		title: 'Workflow store',
		caption: 'Every result you collect across tabs, reorderable and sendable to Plots or Report, saved with your project.',
	},
	{
		image: shotPlotsStudio,
		alt: 'Plots studio: a ten-study forest plot of risk ratios with a random-effects pooled estimate of 0.69, plot-type and drawing-engine controls on the left, and a Reproducible R panel underneath.',
		title: 'Plots studio',
		caption: 'Forest and funnel plots re-drawn from your saved analysis, with the exact R that drew the preview shown beneath.',
	},
	{
		image: shotReportBuilder,
		alt: 'Reproducible report builder with checkboxes for methods, PRISMA flow, included studies, pooled result, forest plot, heterogeneity, reproducible code and packages used, plus HTML, PDF and R Markdown output formats.',
		title: 'Report builder',
		caption: 'Choose sections, export HTML, PDF or .Rmd, or download a reproducibility bundle that re-runs anywhere.',
	},
	{
		image: shotGradeSof,
		alt: 'GRADE certainty-of-evidence form with the five downgrade domains (risk of bias, inconsistency, indirectness, imprecision, publication bias) and suggestions derived from the live analysis.',
		title: 'GRADE',
		caption: 'Rate certainty across the five domains, with suggestions pre-filled from your own analysis.',
	},
];

const audiences = [
	{
		n: '01',
		title: 'Clinical researchers',
		body: 'Run a defensible pairwise or network meta-analysis without writing R. RoB 2, ROBINS-I, QUADAS-2, GRADE, and PRISMA flow are built in.',
	},
	{
		n: '02',
		title: 'Students and educators',
		body: 'Learn by doing: a guided tour, one-click worked examples, and a plain-language interpretation on every result. The generated R is a teaching tool in itself.',
	},
	{
		n: '03',
		title: 'Methodologists',
		body: 'Three-level models, cluster-robust SEs, meta-regression, trim-and-fill, leave-one-out and influence diagnostics, with the exact code captured for every step.',
	},
];

const faqs = [
	{
		q: 'Is it free?',
		a: 'Free while in beta. We will give plenty of notice and a fair offer before anything changes.',
	},
	{
		q: 'Is my data private?',
		a: 'Analyses run in ephemeral, RAM-backed isolated containers hosted in the EU and destroyed at the end of your session. Please do not upload patient-level identifiable data; MetaProc works on the aggregate, study-level data a meta-analysis needs.',
	},
	{
		q: 'Can I see the code my analysis ran?',
		a: 'Yes, that is the whole point. Every model, table, and figure is produced by building R code from your choices, running that exact code, and showing you the same text in a copyable panel. What you see is what ran.',
	},
	{
		q: 'Web or desktop?',
		a: 'The browser app needs nothing installed and is always current. A desktop build (bundling R and all packages for fully-offline use) is planned. See the web-vs-desktop comparison in the docs.',
	},
	{
		q: 'How do I cite it?',
		a: 'A citation and the exact package versions ship in every report and reproducibility bundle (via sessionInfo() and renv.lock), so your write-up names metaproc and the underlying engines (metafor, netmeta and friends) with the versions you actually used.',
	},
	{
		q: 'What is the license?',
		a: 'The code is GPL-3.0-or-later (built on the GPL R meta-analysis ecosystem). The name "MetaProc" is a trademark. See the license page for the plain-language version.',
	},
];
---
<BaseLayout title="MetaProc" activePath="/">
	<!-- ===================== HERO ===================== -->
	<section class="hero">
		<div class="mp-container hero__grid">
			<div class="hero__copy mp-rise">
				<p class="mp-eyebrow">Reproducible meta-analysis</p>
				<h1 class="mp-shine">Run a complete meta-analysis in your browser.</h1>
				<p class="hero__sub">
					From data to forest plot to GRADE summary, with the exact R code behind every step.
				</p>
				<div class="hero__cta">
					<a class="mp-cta mp-cta--lg" href="#" data-placeholder="app-url">
						Launch MetaProc free
						<span class="mp-cta__ico" aria-hidden="true">
							<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l5 5-5 5" /></svg>
						</span>
					</a>
					<a class="hero__secondary" href="/download">Prefer the desktop app?</a>
				</div>
			</div>
			<div class="hero__visual mp-rise" style="--mp-rise-delay:.1s">
				<!-- Launch-core ring miniature sits BEHIND the panel, fully contained in
				     this column (pointer-events:none) so it can never reach the CTA. -->
				<div class="hero__core" aria-hidden="true">
					<span class="hero__halo hero__halo--bloom"></span>
					<span class="hero__halo"></span>
					<span class="hero__dashring"></span>
				</div>
				<div class="hero__panel mp-bezel">
					<div class="mp-bezel__core hero__panelcore">
						<ForestPlot />
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ===================== HOW IT WORKS (vertical connected timeline) ======= -->
	<section class="section how" aria-labelledby="how">
		<div class="mp-container">
			<header class="lede mp-reveal">
				<p class="mp-eyebrow">How it works</p>
				<h2 id="how" class="section__title">Three moves, blank workspace to defensible report.</h2>
			</header>
			<ol class="timeline">
				{steps.map((s, i) => (
					<li class="tl mp-reveal" style={`--mp-reveal-delay:${i * 0.09}s`}>
						<div class="tl__rail" aria-hidden="true">
							<span class="tl__n">{s.n}</span>
						</div>
						<div class="tl__body">
							<h3>{s.title}</h3>
							<p>{s.body}</p>
						</div>
					</li>
				))}
			</ol>
			<figure class="how__shot mp-bezel mp-reveal" style="--mp-reveal-delay:.12s">
				<div class="mp-bezel__core how__shotcore">
					<ProofAsset
						image={shotAppOverview}
						alt="MetaProc home screen: a welcome banner with Start: import your data and Plan my analysis buttons, above a five-step Your workflow strip (import data, explore (EDA), run an analysis, plan a pipeline, build a report)."
						caption="The home screen mirrors those steps (import, explore, analyze, pipeline, report) and your whole project saves to a file you can reload later."
						sizes="(min-width: 78rem) 68rem, 94vw"
						widths={[800, 1200, 1600, 2000]}
					/>
				</div>
			</figure>
		</div>
	</section>

	<!-- ===================== FEATURE TOUR (asymmetric bento with rhythm) ====== -->
	<section class="section section--tint tour" aria-labelledby="tour">
		<div class="mp-container">
			<header class="tour__head mp-reveal">
				<h2 id="tour" class="section__title">A tour of the workspace</h2>
				<a class="tour__more" href="/features">
					See the full feature tour
					<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 3l5 5-5 5"/></svg>
				</a>
			</header>
			<div class="bento">
				{tour.map((t, i) => (
					<figure class={`bento__cell mp-reveal${t.feature ? ' bento__cell--feature' : ''}`} style={`--mp-reveal-delay:${i * 0.07}s`}>
						<div class="bento__shot">
							<ProofAsset
								image={t.image}
								alt={t.alt}
								sizes={t.feature ? '(min-width: 64rem) 44rem, 92vw' : '(min-width: 64rem) 22rem, 92vw'}
								widths={[480, 800, 1200, 1600]}
							/>
						</div>
						<figcaption class="bento__cap">
							<span class="bento__title">{t.title}</span>
							<span class="bento__text">{t.caption}</span>
						</figcaption>
					</figure>
				))}
			</div>
		</div>
	</section>

	<!-- ===================== DEMO TEASER (offset editorial band) ============== -->
	<section class="section demo-teaser" aria-labelledby="demo-teaser-title">
		<div class="mp-container">
			<div class="demo-teaser__inner mp-island mp-reveal">
				<div class="demo-teaser__copy">
					<h2 id="demo-teaser-title" class="section__title">See it run</h2>
					<p>
						A 73-second screen capture from the live app: a worked binary-outcome example
						pools ten trials, gets a GRADE rating, and exports a reproducible report.
					</p>
				</div>
				<a class="mp-cta demo-teaser__cta" href="/features#demo">
					Watch the demo
					<span class="mp-cta__ico" aria-hidden="true">
						<svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor"><path d="M4 2.5v11l9-5.5-9-5.5z"/></svg>
					</span>
				</a>
			</div>
		</div>
	</section>

	<!-- ===================== AUDIENCE (editorial numbered stack, hairlines) === -->
	<section class="section who" aria-labelledby="who">
		<div class="mp-container">
			<header class="lede mp-reveal">
				<h2 id="who" class="section__title">Built for the people who do the work</h2>
			</header>
			<ul class="rolelist">
				{audiences.map((a, i) => (
					<li class={`role role--a${i + 1} mp-reveal`} style={`--mp-reveal-delay:${i * 0.08}s`}>
						<span class="role__n" aria-hidden="true">{a.n}</span>
						<h3 class="role__title">{a.title}</h3>
						<p class="role__body">{a.body}</p>
					</li>
				))}
			</ul>
		</div>
	</section>

	<!-- ===================== METHODS (dark code anchor, split) ================ -->
	<section class="section section--code methods-sec" aria-labelledby="methods">
		<div class="mp-container methods">
			<div class="methods__copy mp-reveal">
				<p class="mp-eyebrow mp-eyebrow--code">Validated, not improvised</p>
				<h2 id="methods" class="section__title section__title--light">Methods you can defend</h2>
				<p class="methods__lead">
					MetaProc does not reinvent the statistics. It drives the same gold-standard R
					engines the field already trusts, and it is golden-tested against them: a suite
					of <strong>2,600+ automated tests</strong> checks that every result matches the
					reference engine, byte for byte.
				</p>
				<a class="mp-cta mp-cta--light" href="/methods">
					How we validate
					<span class="mp-cta__ico mp-cta__ico--dark" aria-hidden="true">
						<svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l5 5-5 5"/></svg>
					</span>
				</a>
			</div>
			<ul class="engines mp-reveal" style="--mp-reveal-delay:.1s" aria-label="Underlying engines">
				<li><span class="engines__name">metafor</span><span class="engines__role">pooling and diagnostics</span></li>
				<li><span class="engines__name">netmeta</span><span class="engines__role">network meta-analysis</span></li>
				<li><span class="engines__name">meta</span><span class="engines__role">reference dependency</span></li>
				<li><span class="engines__name">robvis</span><span class="engines__role">risk-of-bias figures</span></li>
				<li><span class="engines__name">esc</span><span class="engines__role">effect-size conversions</span></li>
			</ul>
		</div>
	</section>

	<!-- ===================== DOCS + FAQ (two-column: docs rail + accordion) === -->
	<section class="section section--tint faqdocs" id="faq" aria-labelledby="faq-title">
		<div class="mp-container faqdocs__grid">
			<div class="docs-rail mp-panel mp-panel--bracket mp-reveal">
				<h2 id="docs-teaser" class="docs-rail__title">Read the docs</h2>
				<p>
					New to meta-analysis or new to MetaProc? The Quickstart walks you from a blank
					workspace to a finished forest plot, GRADE summary, and exported report in about
					ten minutes.
				</p>
				<a class="mp-cta mp-cta--outline docs-rail__cta" href="/docs/quickstart">
					Open the Quickstart
					<span class="mp-cta__ico mp-cta__ico--ghost" aria-hidden="true">
						<svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l5 5-5 5"/></svg>
					</span>
				</a>
			</div>
			<div class="faq mp-reveal" style="--mp-reveal-delay:.08s">
				<h2 id="faq-title" class="section__title faq__heading">Frequently asked</h2>
				<div class="faq__list">
					{faqs.map((f) => (
						<details class="faq__item">
							<summary>{f.q}</summary>
							<div class="faq__answer"><p>{f.a}</p></div>
						</details>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ===================== FINAL CTA (centered manifesto) =================== -->
	<section class="section final-cta" aria-labelledby="final">
		<div class="mp-container final-cta__inner mp-reveal">
			<h2 id="final">Your next meta-analysis starts in the browser.</h2>
			<p class="final-cta__sub">No install, no setup. Free while in beta.</p>
			<a class="mp-cta mp-cta--lg" href="#" data-placeholder="app-url">
				Launch MetaProc free
				<span class="mp-cta__ico" aria-hidden="true">
					<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l5 5-5 5"/></svg>
				</span>
			</a>
		</div>
	</section>
</BaseLayout>

<style>
	/* Hero: transparent over the aurora canvas; rise entrance + shine heading. */
	.hero {
		padding-block: clamp(3rem, 7vw, 5.5rem);
	}
	.hero__grid {
		display: grid;
		grid-template-columns: 1.05fr 0.95fr;
		gap: clamp(2rem, 5vw, 4.5rem);
		align-items: center;
	}
	.hero h1 {
		font-size: clamp(2.3rem, 5vw, 3.9rem);
		line-height: 1.04;
		letter-spacing: -0.038em;
		font-weight: 800;
		margin: 0 0 1.1rem;
	}
	.hero__sub {
		font-size: clamp(1.05rem, 1.8vw, 1.28rem);
		color: var(--mp-muted);
		margin: 0 0 2rem;
		max-width: 34rem;
		line-height: 1.55;
	}
	.hero__cta {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}
	.hero__secondary {
		position: relative;
		font-weight: 600;
		color: var(--mp-link);
		text-decoration: none;
	}
	.hero__secondary::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -2px;
		height: 1.5px;
		background: currentColor;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform .25s var(--mp-ease);
	}
	.hero__secondary:hover::after { transform: scaleX(1); }

	/* Visual column: the ring lives BEHIND the panel and is contained within this
	   column's own box (inset:0, pointer-events:none) so it can never overlap the
	   launch CTA in the copy column (the reported bug). */
	.hero__visual {
		position: relative;
		isolation: isolate;
		padding: clamp(1.25rem, 3.5vw, 2.75rem);
	}
	.hero__panel {
		position: relative;
		z-index: 1;
	}
	.hero__panelcore { padding: 1.15rem 1.4rem; }

	.hero__core {
		position: absolute;
		inset: 0;
		z-index: 0;
		display: grid;
		place-items: center;
		pointer-events: none;
		animation: mp-ringbreathe 5.5s ease-in-out infinite;
		will-change: transform;
	}
	.hero__halo {
		grid-area: 1 / 1;
		width: min(94%, 380px);
		aspect-ratio: 1;
		border-radius: 50%;
		background: conic-gradient(from 0deg, var(--mp-g1), var(--mp-g2), var(--mp-g1), var(--mp-g2), var(--mp-g1));
		-webkit-mask: radial-gradient(closest-side, transparent 0 79%, #000 80% 100%);
		mask: radial-gradient(closest-side, transparent 0 79%, #000 80% 100%);
		opacity: .82;
		animation: mp-spin 16s linear infinite;
		will-change: transform;
	}
	.hero__halo--bloom { filter: blur(16px) saturate(1.2); opacity: .42; }
	.hero__dashring {
		grid-area: 1 / 1;
		width: min(100%, 408px);
		aspect-ratio: 1;
		border-radius: 50%;
		border: 1.5px dashed color-mix(in srgb, var(--mp-accent3) 48%, transparent);
		animation: mp-spin 44s linear infinite reverse;
		will-change: transform;
	}

	@media (max-width: 820px) {
		.hero__grid { grid-template-columns: 1fr; }
		.hero__visual { padding: 2rem 1rem; max-width: 32rem; margin-inline: auto; }
	}

	/* Generic section scaffolding */
	.section { padding-block: clamp(3.25rem, 6.5vw, 5.5rem); }
	.section--tint {
		background: var(--mp-tint);
		border-block: 1px solid var(--mp-hair);
	}
	/* Dark "code anchor" band: stays dusk in BOTH moods (BRAND §3). */
	.section--code {
		background:
			radial-gradient(60% 90% at 85% 10%, color-mix(in srgb, var(--mp-g2) 12%, transparent), transparent 60%),
			linear-gradient(135deg, #0D141B 0%, #101A22 100%);
		border-block: 1px solid var(--mp-code-edge);
	}
	.section__title {
		font-size: clamp(1.6rem, 3vw, 2.2rem);
		letter-spacing: -0.018em;
		line-height: 1.12;
		margin: 0;
		max-width: 22ch;
	}
	.section__title--light { color: #EEF4FB; }

	/* Section ledes (headline blocks) share one rhythm. */
	.lede { margin-bottom: clamp(2rem, 4vw, 3rem); max-width: 44rem; }
	.lede .section__title { margin-top: 0.35rem; }
	.mp-eyebrow--code { color: var(--mp-accent); }

	/* ---- How it works: vertical connected timeline ------------------------- */
	.timeline {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0;
		max-width: 46rem;
	}
	.tl {
		display: grid;
		grid-template-columns: 3.4rem 1fr;
		gap: 1.4rem;
		padding-bottom: 2.2rem;
	}
	.tl:last-child { padding-bottom: 0; }
	.tl__rail {
		position: relative;
		display: flex;
		justify-content: center;
	}
	/* The connector line runs down the rail between the numbered nodes. */
	.tl__rail::before {
		content: "";
		position: absolute;
		top: 3.4rem;
		bottom: -2.2rem;
		width: 2px;
		background: linear-gradient(var(--mp-edge), color-mix(in srgb, var(--mp-brand) 26%, transparent));
	}
	.tl:last-child .tl__rail::before { display: none; }
	.tl__n {
		position: relative;
		z-index: 1;
		display: grid;
		place-items: center;
		width: 3.1rem;
		height: 3.1rem;
		border-radius: 50%;
		background: var(--mp-grad-cta);
		color: #fff;
		font-weight: 800;
		font-size: 1.2rem;
		font-family: var(--font-mono, monospace);
		box-shadow: 0 0 22px -7px var(--mp-glow), inset 0 1px 0 rgba(255, 255, 255, .25);
	}
	.tl__body { padding-top: 0.35rem; }
	.tl__body h3 { margin: 0 0 0.4rem; font-size: 1.3rem; letter-spacing: -0.01em; }
	.tl__body p { margin: 0; color: var(--mp-muted); max-width: 38rem; }

	/* App overview shot: a double-bezel enclosure (real elevation). */
	.how__shot { margin: clamp(2.5rem, 5vw, 3.5rem) 0 0; }
	.how__shotcore { padding: 0; line-height: 0; }
	.how__shotcore :global(.mp-proof img) {
		border: 0;
		border-radius: 20px;
		box-shadow: none;
	}
	.how__shotcore :global(.mp-proof figcaption) {
		padding: 0.85rem 1.1rem 0.1rem;
		line-height: 1.5;
	}

	/* ---- Feature tour: asymmetric bento with rhythm ------------------------ */
	.tour__head {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
		margin-bottom: clamp(1.75rem, 3.5vw, 2.5rem);
	}
	.tour__more {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--mp-link);
		font-weight: 600;
		text-decoration: none;
		white-space: nowrap;
	}
	.tour__more svg { transition: transform .2s var(--mp-ease); }
	.tour__more:hover svg { transform: translateX(3px); }

	.bento {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
	}
	/* The feature tile (code panel) spans the full first row. */
	.bento__cell--feature { grid-column: 1 / -1; }
	.bento__cell {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}
	.bento__shot {
		position: relative;
		border-radius: var(--mp-radius-lg);
		overflow: hidden;
		border: 1px solid var(--mp-edge);
		box-shadow: var(--mp-shadow-panel), inset 0 1px 0 var(--mp-hair);
