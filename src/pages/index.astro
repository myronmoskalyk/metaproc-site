<script>
	// Launch core: click burst ring + scale punch on press (skipped under reduced
	// motion, since the rings already animate via CSS, which the global rule disables).
	(function () {
		const reduce =
			window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (reduce) return;
		const core = document.querySelector<HTMLElement>('.launchcore');
		const btn = core && core.querySelector<HTMLElement>('.launchcore__btn');
		if (!core || !btn) return;
		core.addEventListener('pointerdown', () => {
			const burst = document.createElement('span');
			burst.className = 'launchcore__burst';
			core.appendChild(burst);
			burst.addEventListener('animationend', () => burst.remove());
			if (btn.animate) {
				btn.animate(
					[{ transform: 'scale(.92)' }, { transform: 'scale(1.05)' }, { transform: 'scale(1)' }],
					{ duration: 440, easing: 'cubic-bezier(.22,.61,.36,1)' },
				);
			}
		});
	})();
</script>
