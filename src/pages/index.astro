---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProofAsset from '../components/ProofAsset.astro';

// Real screenshots from the live Orbital app (recaptured 2026-06-13 from the
// native app on 127.0.0.1:7991, teal/amber Orbital UI, not the old violet era).
import shotAppOverview from '../assets/proof/hero-app-overview.png';
import shotWorkflowStore from '../assets/proof/workflow-store.png';
import shotPlotsStudio from '../assets/proof/plots-studio.png';
import shotReportBuilder from '../assets/proof/report-builder.png';
import shotCodePanel from '../assets/proof/code-panel.png';

const steps = [
	{
		n: '1',
		title: 'Import',
		body: 'Upload a CSV or Excel workbook, or load a bundled example. MetaProc detects headers and flags duplicate or out-of-range studies as you go.',
	},
	{
		n: '2',
		title: 'Analyze',
		body: 'Choose a template, map your columns, and run. Forest and funnel plots, heterogeneity, subgroups, and sensitivity analyses appear instantly.',
	},
	{
		n: '3',
		title: 'Report',
		body: 'Build a reproducible report with a GRADE summary, then export a bundle that re-runs in a clean R session and reproduces your pooled estimate.',
	},
];

// Workspace tour: the code panel leads as a wide feature tile (it carries the
// product's whole thesis), three supporting shots fall into a rhythmic grid.
const tour = [
	{
		image: shotCodePanel,
		alt: 'Live R code panel: a metafor script with escalc effect-size, rma model, forest and funnel calls beside the raw random-effects model output it produced.',
		title: 'Live R code panel',
		caption: 'Every analysis shows the exact R it ran, metafor calls included. Copy it, audit it, re-run it.',
		feature: true,
	},
	{
		image: shotWorkflowStore,
		alt: 'MetaProc home screen with the Workflow panel open on the right, holding a saved risk-ratio analysis with buttons to send it to the Plots studio or the Report.',
		title: 'Workflow store',
		caption: 'Collect every result across tabs, then send it straight to Plots or Report.',
	},
	{
		image: shotPlotsStudio,
		alt: 'Plots studio: a ten-study forest plot of risk ratios with a random-effects pooled estimate of 0.69, plot-type and drawing-engine controls on the left, and a Reproducible R panel underneath.',
		title: 'Plots studio',
		caption: 'Forest and funnel plots re-drawn from your saved analysis, code shown beneath.',
	},
	{
		image: shotReportBuilder,
		alt: 'Reproducible report builder with checkboxes for methods, PRISMA flow, included studies, pooled result, forest plot, heterogeneity, reproducible code and packages used, plus HTML, PDF and R Markdown output formats.',
		title: 'Report builder',
		caption: 'Export HTML, PDF or .Rmd, or a reproducibility bundle that re-runs anywhere.',
	},
];

// FAQ trimmed to the three essentials. The fuller list lives in the docs; this
// section keeps the #faq anchor the header nav points to.
const faqs = [
	{
		q: 'Is it free?',
		a: 'Free while in beta. We will give plenty of notice and a fair offer before anything changes.',
	},
	{
		q: 'Is my data private?',
		a: 'Analyses run in ephemeral, RAM-backed isolated containers hosted in the EU and destroyed at the end of your session. Work on the aggregate, study-level data a meta-analysis needs, not patient-level records.',
	},
	{
		q: 'Can I see the code my analysis ran?',
		a: 'Yes, that is the whole point. Every model, table, and figure is produced by building R code from your choices, running that exact code, and showing you the same text in a copyable panel. What you see is what ran.',
	},
];
---
<BaseLayout title="MetaProc" activePath="/">
	<!-- ===================== HERO ===================== -->
	<section class="hero">
		<div class="hero__gridbg" aria-hidden="true"></div>
		<div class="mp-container hero__grid">
			<div class="hero__copy mp-rise">
				<p class="mp-eyebrow">Reproducible meta-analysis</p>
				<h1 class="mp-shine">Run a complete meta-analysis in your browser.</h1>
				<p class="hero__sub">
					From raw data to forest plot to GRADE summary, with the exact R code behind every step.
				</p>
				<div class="hero__cta">
					<a class="hero__secondary" href="/download">Prefer the desktop app?</a>
				</div>
			</div>
			<div class="hero__visual mp-rise" style="--mp-rise-delay:.1s">
				<!-- Launch core: the animated launch button. Rings (breathe + spin + sonar)
				     are decorative; the <a> is the real, accessible primary CTA. The whole
				     unit is perfectly concentric and optically centered in this column. -->
				<a class="launchcore" href="#" data-placeholder="app-url" aria-label="Launch MetaProc, free">
					<span class="launchcore__rings" aria-hidden="true">
						<span class="launchcore__sonar"></span>
						<span class="launchcore__sonar launchcore__sonar--2"></span>
						<span class="launchcore__halo launchcore__halo--bloom"></span>
						<span class="launchcore__halo"></span>
						<span class="launchcore__dash"></span>
					</span>
					<span class="launchcore__btn">
						<span class="launchcore__mark" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none">
								<rect x="11" y="4" width="2" height="16" rx="1" fill="#fff" opacity=".5" />
								<polygon points="12,8 18.5,12 12,16 5.5,12" fill="#fff" />
							</svg>
						</span>
						<span class="launchcore__label">Launch</span>
						<span class="launchcore__free">free</span>
					</span>
				</a>
			</div>
		</div>
	</section>

	<!-- ===================== HOW IT WORKS (vertical connected timeline) ======= -->
	<section class="section how" aria-labelledby="how">
		<div class="mp-container">
			<header class="lede mp-reveal">
				<h2 id="how" class="section__title">A blank workspace to a defensible report, in three moves.</h2>
			</header>
			<div class="how__grid">
				<ol class="timeline">
					{steps.map((s, i) => (
						<li class="tl mp-reveal" style={`--mp-reveal-delay:${i * 0.09}s`}>
							<div class="tl__rail" aria-hidden="true">
								<span class="tl__n">{s.n}</span>
							</div>
							<div class="tl__body">
								<h3>{s.title}</h3>
								<p>{s.body}</p>
							</div>
						</li>
					))}
				</ol>
				<figure class="how__shot mp-bezel mp-reveal" style="--mp-reveal-delay:.12s">
					<div class="mp-bezel__core how__shotcore">
						<ProofAsset
							image={shotAppOverview}
							alt="MetaProc home screen: a welcome banner with Start: import your data and Plan my analysis buttons, above a five-step Your workflow strip (import data, explore (EDA), run an analysis, plan a pipeline, build a report)."
							caption="The home screen mirrors those steps, and your whole project saves to a file you can reload later."
							sizes="(min-width: 60rem) 30rem, 94vw"
							widths={[600, 900, 1200, 1600]}
						/>
					</div>
				</figure>
			</div>
		</div>
	</section>

	<!-- ===================== WORKSPACE TOUR (asymmetric bento + demo CTA) ===== -->
	<section class="section section--tint tour" aria-labelledby="tour">
		<div class="mp-container">
			<header class="tour__head mp-reveal">
				<h2 id="tour" class="section__title">A workspace built around the code it runs.</h2>
				<p class="tour__sub">Four corners of MetaProc. Each result carries the exact R that produced it.</p>
			</header>
			<div class="bento">
				{tour.map((t, i) => (
					<figure class={`bento__cell mp-reveal${t.feature ? ' bento__cell--feature' : ''}`} style={`--mp-reveal-delay:${i * 0.07}s`}>
						<div class="bento__shot">
							<ProofAsset
								image={t.image}
								alt={t.alt}
								sizes={t.feature ? '(min-width: 64rem) 44rem, 92vw' : '(min-width: 64rem) 21rem, 92vw'}
								widths={[480, 800, 1200, 1600]}
							/>
						</div>
						<figcaption class="bento__cap">
							<span class="bento__title">{t.title}</span>
							<span class="bento__text">{t.caption}</span>
						</figcaption>
					</figure>
				))}
			</div>
			<div class="tour__foot mp-reveal">
				<a class="tour__more" href="/features">
					See the full feature tour
					<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 3l5 5-5 5"/></svg>
				</a>
				<a class="mp-cta mp-cta--outline tour__demo" href="/features#demo">
					Watch the 73-second demo
					<span class="mp-cta__ico mp-cta__ico--ghost" aria-hidden="true">
						<svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor"><path d="M4 2.5v11l9-5.5-9-5.5z"/></svg>
					</span>
				</a>
			</div>
		</div>
	</section>

	<!-- ===================== METHODS (dark code anchor, split) ================ -->
	<section class="section section--code methods-sec" aria-labelledby="methods">
		<div class="mp-container methods">
			<div class="methods__copy mp-reveal">
				<p class="mp-eyebrow mp-eyebrow--code">Validated, not improvised</p>
				<h2 id="methods" class="section__title section__title--light">Methods you can defend</h2>
				<p class="methods__lead">
					MetaProc drives the same gold-standard R engines the field already trusts, and it is
					golden-tested against them: <strong>2,600+ automated tests</strong> check that every
					result matches the reference engine, byte for byte.
				</p>
				<a class="mp-cta mp-cta--light" href="/methods">
					How we validate
					<span class="mp-cta__ico mp-cta__ico--dark" aria-hidden="true">
						<svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l5 5-5 5"/></svg>
					</span>
				</a>
			</div>
			<ul class="engines mp-reveal" style="--mp-reveal-delay:.1s" aria-label="Underlying engines">
				<li><span class="engines__name">metafor</span><span class="engines__role">pooling and diagnostics</span></li>
				<li><span class="engines__name">netmeta</span><span class="engines__role">network meta-analysis</span></li>
				<li><span class="engines__name">meta</span><span class="engines__role">reference dependency</span></li>
				<li><span class="engines__name">robvis</span><span class="engines__role">risk-of-bias figures</span></li>
				<li><span class="engines__name">esc</span><span class="engines__role">effect-size conversions</span></li>
			</ul>
		</div>
	</section>

	<!-- ===================== FAQ + FINAL CTA (closing block) ================== -->
	<section class="section close" id="faq" aria-labelledby="final">
		<div class="mp-container close__grid">
			<div class="faq mp-reveal">
				<h2 id="faq-title" class="section__title faq__heading">Frequently asked</h2>
				<div class="faq__list">
					{faqs.map((f) => (
						<details class="faq__item">
							<summary>{f.q}</summary>
							<div class="faq__answer"><p>{f.a}</p></div>
						</details>
					))}
				</div>
				<a class="faq__more" href="/docs/quickstart">
					More in the Quickstart
					<svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 3l5 5-5 5"/></svg>
				</a>
			</div>

			<div class="final-cta mp-panel mp-panel--bracket mp-reveal" style="--mp-reveal-delay:.08s">
				<h2 id="final">Your next meta-analysis starts in the browser.</h2>
				<p class="final-cta__sub">No install, no setup. Free while in beta.</p>
				<a class="mp-cta mp-cta--lg final-cta__btn" href="#" data-placeholder="app-url">
					Launch MetaProc free
					<span class="mp-cta__ico" aria-hidden="true">
						<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l5 5-5 5"/></svg>
					</span>
				</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* Hero: transparent over the aurora canvas, with a faint graph-paper grid
	   (masked to fade at the edges) for a quietly mathematical, statistical feel. */
	.hero {
		position: relative;
		isolation: isolate;
		padding-block: clamp(3.5rem, 8vw, 6.5rem);
	}
	.hero__gridbg {
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		background-image:
			linear-gradient(var(--mp-hair) 1px, transparent 1px),
			linear-gradient(90deg, var(--mp-hair) 1px, transparent 1px);
		background-size: 46px 46px;
		-webkit-mask: radial-gradient(72% 80% at 74% 50%, #000 0%, transparent 76%);
		mask: radial-gradient(72% 80% at 74% 50%, #000 0%, transparent 76%);
		opacity: .55;
	}
	.hero__grid {
		display: grid;
		grid-template-columns: 1.04fr 0.96fr;
		gap: clamp(2rem, 5vw, 5rem);
		align-items: center;
	}
	.hero h1 {
		font-size: clamp(2.35rem, 5.1vw, 4.1rem);
		line-height: 1.03;
		letter-spacing: -0.04em;
		font-weight: 800;
		margin: 0 0 1.15rem;
	}
	.hero__sub {
		font-size: clamp(1.06rem, 1.8vw, 1.3rem);
		color: var(--mp-muted);
		margin: 0 0 2rem;
		max-width: 33rem;
		line-height: 1.55;
	}
	.hero__cta {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}
	.hero__secondary {
		position: relative;
		font-weight: 600;
		color: var(--mp-link);
		text-decoration: none;
	}
	.hero__secondary::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -2px;
		height: 1.5px;
		background: currentColor;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform .25s var(--mp-ease);
	}
	.hero__secondary:hover::after { transform: scaleX(1); }

	/* ---- Launch core: the animated launch button. A pressable brand-gradient core
	   sitting dead-center inside a breathing + spinning ring system with radiating
	   sonar pulses; click fires a burst ring + scale-punch (the script below). The
	   container is a square stage sized to the OUTERMOST ring (the 117% dash) so the
	   whole unit centers as one optical object, with no clipping. Reduced-motion gated. */
	.hero__visual {
		display: grid;
		place-items: center;
		min-height: clamp(330px, 37vw, 440px);
	}
	/* The launch core is built as ONE square grid stage: every layer lives in the
	   same single grid cell (grid-area 1/1) and is centered by `place-items: center`.
	   No translate() anywhere, so the spin / breathe / press transforms can never
	   clobber the centering. The stage side equals the outermost ring (the dash),
	   so the whole unit is self-contained and centers as a single optical object.
	   `--halo` drives the inner ring system; every other radius is derived from it. */
	.launchcore {
		--halo: clamp(228px, 25vw, 300px);   /* the teal halo + sonar + btn system */
		--stage: calc(var(--halo) * 1.17);   /* = the dash ring, the outer bound */
		position: relative;
		display: grid;
		/* Explicit FIXED single track (not 1fr/auto): a fr/auto row takes a min-content
		   floor from its tallest child, which the 117% dash would inflate past the box
		   and push every ring off-center. A fixed --stage track ignores min-content, so
		   children overflow symmetrically and stay concentric to the box center. */
		grid-template: "core" var(--stage) / var(--stage);
		place-content: center;
		place-items: center;
		place-self: center;
		width: var(--stage);
		height: var(--stage);
		border-radius: 50%;
		text-decoration: none;
		isolation: isolate;
	}
	.launchcore > * { grid-area: core; min-width: 0; min-height: 0; }
	/* Rings wrapper: a centered square of side --halo, same fixed-track trick so the
	   117% dash inside it cannot inflate the row and shift the rings downward. The
	   breathe scale animates about the box center (no translate to fight). */
	.launchcore__rings {
		display: grid;
		grid-template: "r" var(--halo) / var(--halo);
		place-content: center;
		place-items: center;
		width: var(--halo);
		height: var(--halo);
		pointer-events: none;
		z-index: 0;
		animation: mp-ringbreathe 5.5s ease-in-out infinite;
		will-change: transform;
	}
	.launchcore__rings > * { grid-area: r; min-width: 0; min-height: 0; }
	.launchcore__halo {
		width: 100%;
		aspect-ratio: 1;
		border-radius: 50%;
		background: conic-gradient(from 0deg, var(--mp-g1), var(--mp-g2), var(--mp-g1), var(--mp-g2), var(--mp-g1));
		-webkit-mask: radial-gradient(closest-side, transparent 0 77%, #000 79% 100%);
		mask: radial-gradient(closest-side, transparent 0 77%, #000 79% 100%);
		opacity: .85;
		animation: mp-spin 16s linear infinite;
		will-change: transform;
	}
	.launchcore__halo--bloom { filter: blur(18px) saturate(1.25); opacity: .5; }
	.launchcore__dash {
		width: 117%;
		aspect-ratio: 1;
		border-radius: 50%;
		border: 1.5px dashed color-mix(in srgb, var(--mp-accent3) 52%, transparent);
		animation: mp-spin 40s linear infinite reverse;
		will-change: transform;
	}
	.launchcore__sonar {
		width: 66%;
		aspect-ratio: 1;
		border-radius: 50%;
		border: 1.5px solid color-mix(in srgb, var(--mp-brand) 55%, transparent);
		animation: mp-sonar 4.2s ease-out infinite;
		will-change: transform, opacity;
	}
	.launchcore__sonar--2 { animation-delay: 2.1s; }
	/* The pressable core, a plain centered grid cell (no absolute / translate). Its
	   diameter is 0.52 of the halo, concentric to the stage by construction. */
	.launchcore__btn {
		z-index: 1;
		display: grid;
		place-items: center;
		gap: .08rem;
		width: calc(var(--halo) * 0.52);
		height: calc(var(--halo) * 0.52);
		border-radius: 50%;
		background: var(--mp-grad-cta);
		color: #fff;
		box-shadow:
			0 24px 52px -24px var(--mp-glow),
			0 6px 22px -10px var(--mp-glow),
			inset 0 0 0 1px rgba(255, 255, 255, .14),
			inset 0 2px 0 rgba(255, 255, 255, .24);
		overflow: hidden;
		transition: transform .25s var(--mp-ease), box-shadow .25s ease, filter .25s ease;
	}
	.launchcore:hover .launchcore__btn {
		transform: scale(1.05);
		filter: brightness(1.07);
		box-shadow:
			0 28px 60px -24px var(--mp-glow),
			0 6px 22px -10px var(--mp-glow),
			inset 0 0 0 1px rgba(255, 255, 255, .2),
			inset 0 2px 0 rgba(255, 255, 255, .3);
	}
	.launchcore:active .launchcore__btn { transform: scale(.97); }
	.launchcore:hover .launchcore__halo { animation-duration: 8s; }
	.launchcore:focus-visible { outline: none; }
	.launchcore:focus-visible .launchcore__btn {
		box-shadow:
			0 24px 52px -24px var(--mp-glow),
			inset 0 0 0 1px rgba(255, 255, 255, .14),
			0 0 0 4px var(--mp-focus);
	}
	.launchcore__mark svg { width: clamp(26px, 3.6vw, 38px); height: auto; display: block; }
	.launchcore__label {
		font-weight: 800;
		font-size: clamp(1rem, 1.5vw, 1.2rem);
		letter-spacing: -.01em;
		line-height: 1;
	}
	.launchcore__free {
		font-size: .62rem;
		font-weight: 700;
		letter-spacing: .14em;
		text-transform: uppercase;
		opacity: .85;
	}
	/* Click burst ring (injected by the script). A centered grid cell scaling out. */
	.launchcore__burst {
		grid-area: core;
		justify-self: center;
		align-self: center;
		width: calc(var(--halo) * 0.52);
		height: calc(var(--halo) * 0.52);
		border-radius: 50%;
		border: 2px solid color-mix(in srgb, var(--mp-brand) 70%, transparent);
		pointer-events: none;
		z-index: 0;
		animation: mp-burst .56s ease-out forwards;
	}

	@keyframes mp-sonar {
		0% { transform: scale(.66); opacity: .5; }
		100% { transform: scale(1.5); opacity: 0; }
	}
	@keyframes mp-burst {
		from { transform: scale(1); opacity: .7; }
		to { transform: scale(2.3); opacity: 0; }
	}

	@media (max-width: 820px) {
		.hero__grid { grid-template-columns: 1fr; }
		.hero__visual { margin-top: 0.75rem; }
		.hero__gridbg {
			-webkit-mask: radial-gradient(94% 56% at 50% 60%, #000, transparent 82%);
			mask: radial-gradient(94% 56% at 50% 60%, #000, transparent 82%);
		}
	}

	/* Generic section scaffolding */
	.section { padding-block: clamp(4rem, 8vw, 7rem); }
	.section--tint {
		background: var(--mp-tint);
		border-block: 1px solid var(--mp-hair);
	}
	/* Dark "code anchor" band: stays dusk in BOTH moods (BRAND §3). */
	.section--code {
		background:
			radial-gradient(60% 90% at 85% 10%, color-mix(in srgb, var(--mp-g2) 12%, transparent), transparent 60%),
			linear-gradient(135deg, #0D141B 0%, #101A22 100%);
		border-block: 1px solid var(--mp-code-edge);
	}
	.section__title {
		font-size: clamp(1.7rem, 3.1vw, 2.35rem);
		letter-spacing: -0.022em;
		line-height: 1.12;
		margin: 0;
		max-width: 24ch;
		text-wrap: balance;
	}
	.section__title--light { color: #EEF4FB; }

	/* Section ledes (headline blocks) share one rhythm. */
	.lede { margin-bottom: clamp(2.25rem, 4.5vw, 3.25rem); max-width: 44rem; }
	.lede .section__title { margin-top: 0.4rem; }
	.mp-eyebrow--code { color: var(--mp-accent); }

	/* ---- How it works: timeline beside the home-screen shot ----------------- */
	.how__grid {
		display: grid;
		grid-template-columns: 1.05fr 0.95fr;
		gap: clamp(2.5rem, 5vw, 4rem);
		align-items: center;
	}
	.timeline {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0;
		max-width: 34rem;
	}
	.tl {
		display: grid;
		grid-template-columns: 3.4rem 1fr;
		gap: 1.4rem;
		padding-bottom: 2.4rem;
	}
	.tl:last-child { padding-bottom: 0; }
	.tl__rail {
		position: relative;
		display: flex;
		justify-content: center;
	}
	/* The connector line runs down the rail between the numbered nodes. */
	.tl__rail::before {
		content: "";
		position: absolute;
		top: 3.4rem;
		bottom: -2.4rem;
		width: 2px;
		background: linear-gradient(var(--mp-edge), color-mix(in srgb, var(--mp-brand) 26%, transparent));
	}
	.tl:last-child .tl__rail::before { display: none; }
	.tl__n {
