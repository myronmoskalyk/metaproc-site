---
// Placeholder slot for a real UI screenshot (Stage 4 captures replace these).
// Marked data-proof-asset so the capture tooling can find every slot.
interface Props {
	caption: string;
	label?: string;
	ratio?: string; // aspect-ratio, e.g. "16 / 10"
}
const { caption, label = 'Screenshot', ratio = '16 / 10' } = Astro.props;
---
<figure class="mp-proof" data-proof-asset>
	<div class="mp-proof__box" style={`aspect-ratio:${ratio}`} aria-hidden="true">
		<span class="mp-proof__tag">{label}</span>
		<span class="mp-proof__note">Real screenshot arrives in Stage 4</span>
	</div>
	<figcaption>{caption}</figcaption>
</figure>

<style>
	.mp-proof {
		margin: 0;
	}
	.mp-proof__box {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		width: 100%;
		border: 2px dashed var(--mp-card-border);
		border-radius: var(--mp-radius-lg);
		background: linear-gradient(135deg, #f6f3fd 0%, #eef2fe 100%);
		color: var(--mp-muted);
		text-align: center;
		padding: 1rem;
	}
	.mp-proof__tag {
		font-weight: 700;
		color: var(--mp-violet-deep, #5B21B6);
		font-size: 0.95rem;
	}
	.mp-proof__note {
		font-size: 0.8rem;
	}
	.mp-proof figcaption {
		margin-top: 0.6rem;
		font-size: 0.9rem;
		color: var(--mp-muted);
	}
</style>
