---
// Signature hero visual: an animated inline-SVG forest plot.
// Zero JS: CI whiskers draw in via stroke-dashoffset, study markers fade/scale
// in staggered, and the amber pooled diamond scales in last.
// Colours follow the Orbital plot palette (BRAND.md §8): teal series for
// studies, amber (the "current/pooled" accent) for the summary diamond.
// Full prefers-reduced-motion fallback renders the same plot, static.

// 5 study rows + a summary. x is the effect axis (SVG units); plot spans 70..560.
// null line sits at x=315 (RR/OR = 1). Each study: label, point estimate x,
// CI low/high x, marker size (weight).
const studies = [
	{ name: 'Alvarez 2019', x: 250, lo: 196, hi: 304, w: 8 },
	{ name: 'Boroni 2020', x: 296, lo: 250, hi: 342, w: 11 },
	{ name: 'Chen 2021', x: 232, lo: 168, hi: 296, w: 6 },
	{ name: 'Duarte 2022', x: 284, lo: 240, hi: 328, w: 12 },
	{ name: 'Ek 2023', x: 268, lo: 222, hi: 314, w: 9 },
];
const rowH = 34;
const top = 26;
const nullX = 315;
const summary = { lo: 244, hi: 300, cx: 272 };
const summaryY = top + studies.length * rowH + 14;
---
<div class="mp-forest" role="img" aria-label="Animated forest plot: five study effect estimates with confidence intervals, all favouring treatment, pooled into a summary diamond left of the no-effect line.">
	<svg viewBox="0 0 620 270" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
		<!-- No-effect reference line -->
		<line class="mp-forest__null" x1={nullX} y1="14" x2={nullX} y2={summaryY + 18} />

		<!-- Axis baseline + favours labels -->
		<line class="mp-forest__axis" x1="70" y1={summaryY + 28} x2="560" y2={summaryY + 28} />
		<text class="mp-forest__hint" x="150" y={summaryY + 46} text-anchor="middle">favours treatment</text>
		<text class="mp-forest__hint" x="450" y={summaryY + 46} text-anchor="middle">favours control</text>

		{studies.map((s, i) => {
			const y = top + i * rowH;
			const delay = `${0.25 + i * 0.18}s`;
			return (
				<g class="mp-forest__row" style={`--row-delay:${delay}`}>
					<text class="mp-forest__label" x="64" y={y + 4} text-anchor="end">{s.name}</text>
					{/* CI whisker: drawn in via dashoffset */}
					<line class="mp-forest__ci" x1={s.lo} y1={y} x2={s.hi} y2={y} style={`--ci-len:${s.hi - s.lo}`} />
					<line class="mp-forest__cap" x1={s.lo} y1={y - 5} x2={s.lo} y2={y + 5} />
					<line class="mp-forest__cap" x1={s.hi} y1={y - 5} x2={s.hi} y2={y + 5} />
					{/* Square marker: staggered fade/scale in */}
					<rect
						class="mp-forest__marker"
						x={s.x - s.w / 2}
						y={y - s.w / 2}
						width={s.w}
						height={s.w}
						rx="1.5"
					/>
				</g>
			);
		})}

		{/* Summary diamond: amber, scales in last */}
		<polygon
			class="mp-forest__diamond"
			points={`${summary.lo},${summaryY} ${summary.cx},${summaryY - 11} ${summary.hi},${summaryY} ${summary.cx},${summaryY + 11}`}
		/>
		<text class="mp-forest__label mp-forest__label--bold" x="64" y={summaryY + 4} text-anchor="end">Pooled (RE)</text>
	</svg>
</div>

<style>
	.mp-forest {
		width: 100%;
		/* Plot series colours (BRAND §8), tuned per mood so every meaningful
		   graphic keeps ≥3:1 against the panel surface (computed). */
		--plot-line: var(--mp-brand-deep);   /* CI whiskers/caps */
		--plot-marker: #0E9F8E;              /* plot-palette primary teal */
		--plot-diamond: var(--mp-accent-deep); /* pooled = amber (deep on light) */
	}
	:global(html[data-theme='dusk']) .mp-forest {
		--plot-line: var(--mp-brand);
		--plot-marker: var(--mp-g1);
		--plot-diamond: var(--mp-accent-deep);
	}
	.mp-forest svg {
		width: 100%;
		height: auto;
		display: block;
	}

	.mp-forest__null {
		stroke: var(--mp-muted);
		stroke-opacity: 0.55;
		stroke-width: 1.5;
		stroke-dasharray: 4 4;
	}
	.mp-forest__axis {
		stroke: var(--mp-edge);
		stroke-width: 1;
	}
	.mp-forest__label {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: 11px;
		fill: var(--mp-ink);
		fill-opacity: 0.85;
	}
	.mp-forest__label--bold {
		font-weight: 700;
		fill: var(--mp-link);
		fill-opacity: 1;
	}
	.mp-forest__hint {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-size: 9.5px;
		fill: var(--mp-muted);
		letter-spacing: 0.02em;
	}
	.mp-forest__ci {
		stroke: var(--plot-line);
		stroke-width: 2;
		stroke-linecap: round;
	}
	.mp-forest__cap {
		stroke: var(--plot-line);
		stroke-width: 2;
		stroke-linecap: round;
	}
	.mp-forest__marker {
		fill: var(--plot-marker);
	}
	.mp-forest__diamond {
		fill: var(--plot-diamond);
		stroke: var(--mp-panel);
		stroke-width: 1;
	}

	/* ---- Animation (opt-in: only when motion is allowed) -------------------- */
	@media (prefers-reduced-motion: no-preference) {
		.mp-forest__ci {
			stroke-dasharray: var(--ci-len);
			stroke-dashoffset: var(--ci-len);
			animation: mp-draw-ci 0.6s ease-out forwards;
			animation-delay: var(--row-delay);
		}
		.mp-forest__cap {
			opacity: 0;
			animation: mp-fade 0.4s ease-out forwards;
			animation-delay: calc(var(--row-delay) + 0.4s);
		}
		.mp-forest__marker {
			opacity: 0;
			transform: scale(0.2);
			transform-origin: center;
			transform-box: fill-box;
			animation: mp-pop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
			animation-delay: calc(var(--row-delay) + 0.25s);
		}
		.mp-forest__label {
			opacity: 0;
			animation: mp-fade 0.5s ease-out forwards;
			animation-delay: var(--row-delay);
		}
		.mp-forest__diamond {
			opacity: 0;
			transform: scale(0.2);
			transform-origin: center;
			transform-box: fill-box;
			animation: mp-pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
			/* last: after the final study row resolves */
			animation-delay: 1.45s;
		}
		.mp-forest__label--bold {
			opacity: 0;
			animation: mp-fade 0.6s ease-out forwards;
			animation-delay: 1.5s;
		}
	}

	@keyframes mp-draw-ci {
		to { stroke-dashoffset: 0; }
	}
	@keyframes mp-pop {
		to { opacity: 1; transform: scale(1); }
	}
	@keyframes mp-fade {
		to { opacity: 1; }
	}
</style>
