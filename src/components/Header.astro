---
// Shared site header — the only GLASS surface (BRAND §5: glass on chrome only).
// Wordmark + forest-plot logo tile, primary nav, mood toggle, single CTA.
const { activePath = '' } = Astro.props;
const nav = [
	{ label: 'Features', href: '/features' },
	{ label: 'Methods', href: '/methods' },
	{ label: 'Docs', href: '/docs' },
	{ label: 'FAQ', href: '/#faq' },
];
---
<header class="mp-header">
	<div class="mp-container mp-header__inner">
		<a href="/" class="mp-wordmark" aria-label="MetaProc home">
			<span class="mp-wordmark__tile" aria-hidden="true">
				<!-- forest-plot mark: reference axis + pooled diamond (matches favicon) -->
				<svg viewBox="0 0 24 24" fill="none">
					<rect x="11" y="4" width="2" height="16" rx="1" fill="#fff" opacity=".45" />
					<polygon points="12,8 18.5,12 12,16 5.5,12" fill="#fff" />
				</svg>
			</span>
			metaproc
		</a>

		<nav class="mp-nav" aria-label="Primary">
			<ul>
				{nav.map((item) => (
					<li>
						<a
							href={item.href}
							aria-current={activePath === item.href ? 'page' : undefined}
						>{item.label}</a>
					</li>
				))}
			</ul>
		</nav>

		<button
			class="mp-mood"
			id="mp-mood-toggle"
			type="button"
			aria-pressed="false"
			aria-label="Switch to deep dusk"
			title="Switch mood"
		>
			<svg class="mp-mood__sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4.5" />
				<path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4" />
			</svg>
			<svg class="mp-mood__moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
			</svg>
		</button>

		<a class="mp-cta mp-cta--sm" href="#" data-placeholder="app-url">Launch MetaProc</a>
	</div>
</header>

<style>
	.mp-header {
		position: sticky;
		top: 0;
		z-index: 40;
		background: var(--mp-glass);
		-webkit-backdrop-filter: saturate(140%) blur(14px);
		backdrop-filter: saturate(140%) blur(14px);
		border-bottom: 1px solid var(--mp-edge);
	}
	.mp-header__inner {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		min-height: 4rem;
	}
	.mp-wordmark {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-weight: 800;
		font-size: 1.3rem;
		letter-spacing: -0.02em;
		color: var(--mp-ink);
		text-decoration: none;
	}
	.mp-wordmark:hover { color: var(--mp-ink); }
	.mp-wordmark__tile {
		width: 30px;
		height: 30px;
		flex: none;
		border-radius: 9px;
		display: grid;
		place-items: center;
		background: linear-gradient(160deg, var(--mp-g1), var(--mp-g2));
		box-shadow: 0 0 22px -6px var(--mp-glow), inset 0 1px 0 rgba(255, 255, 255, .25);
	}
	.mp-wordmark__tile svg {
		width: 19px;
		height: 19px;
		display: block;
	}
	.mp-nav {
		margin-left: auto;
	}
	.mp-nav ul {
		display: flex;
		gap: 1.4rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.mp-nav a {
		color: var(--mp-ink);
		text-decoration: none;
		font-weight: 500;
		padding: 0.3rem 0;
		border-bottom: 2px solid transparent;
		transition: color .15s ease, border-color .15s ease;
	}
	.mp-nav a:hover,
	.mp-nav a[aria-current='page'] {
		color: var(--mp-link);
		border-bottom-color: var(--mp-brand);
	}

	/* Mood toggle — icon button on glass (mockup .iconbtn language). */
	.mp-mood {
		width: 34px;
		height: 34px;
		flex: none;
		display: grid;
		place-items: center;
		cursor: pointer;
		background: transparent;
		border: 1px solid var(--mp-edge);
		border-radius: 10px;
		color: var(--mp-ink);
		padding: 0;
		transition: border-color .2s ease, transform .12s var(--mp-ease);
	}
	.mp-mood:hover { border-color: var(--mp-brand); }
	.mp-mood:active { transform: scale(.92); }
	.mp-mood svg {
		width: 18px;
		height: 18px;
		grid-area: 1 / 1;
	}
	/* Icon shows the CURRENT mood: sun in warm light, moon in deep dusk. */
	.mp-mood__moon { display: none; }
	:global(html[data-theme='dusk']) .mp-mood__sun { display: none; }
	:global(html[data-theme='dusk']) .mp-mood__moon { display: block; }

	@media (max-width: 640px) {
		.mp-nav { display: none; }
	}
</style>

<script>
	// Mood toggle: flips [data-theme] on <html>, persists to localStorage.
	// The pre-paint script in BaseLayout reads the same key ('mp-site-mood').
	const KEY = 'mp-site-mood';
	const btn = document.getElementById('mp-mood-toggle');

	function syncButton(mood: string) {
		if (!btn) return;
		const dusk = mood === 'dusk';
		btn.setAttribute('aria-pressed', dusk ? 'true' : 'false');
		btn.setAttribute('aria-label', dusk ? 'Switch to warm light' : 'Switch to deep dusk');
	}

	if (btn) {
		syncButton(document.documentElement.getAttribute('data-theme') === 'dusk' ? 'dusk' : 'light');
		btn.addEventListener('click', () => {
			const next =
				document.documentElement.getAttribute('data-theme') === 'dusk' ? 'light' : 'dusk';
			document.documentElement.setAttribute('data-theme', next);
			try {
				localStorage.setItem(KEY, next);
			} catch (e) {
				/* storage unavailable — mood still flips for this page */
			}
			syncButton(next);
		});
	}
</script>
