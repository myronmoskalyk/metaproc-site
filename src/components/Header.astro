---
// Shared site header: a floating glass "island" nav (BRAND §5: glass on chrome).
// Wordmark + forest-plot tile, primary nav, mood toggle, a single CTA, and a
// glass mobile sheet (the nav no longer just vanishes on small screens).
const { activePath = '' } = Astro.props;
const nav = [
	{ label: 'Features', href: '/features' },
	{ label: 'Methods', href: '/methods' },
	{ label: 'Docs', href: '/docs' },
	{ label: 'FAQ', href: '/#faq' },
];
---
<span class="mp-head-sentinel" aria-hidden="true"></span>
<div class="mp-headwrap">
	<header class="mp-header mp-island" aria-label="Site header">
		<a href="/" class="mp-wordmark" aria-label="MetaProc home">
			<span class="mp-wordmark__tile" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none">
					<rect x="11" y="4" width="2" height="16" rx="1" fill="var(--mp-on-brand)" opacity=".45" />
					<polygon points="12,8 18.5,12 12,16 5.5,12" fill="var(--mp-on-brand)" />
				</svg>
			</span>
			metaproc
		</a>

		<nav class="mp-nav" aria-label="Primary">
			<ul>
				{nav.map((item) => (
					<li>
						<a href={item.href} aria-current={activePath === item.href ? 'page' : undefined}>
							{item.label}
						</a>
					</li>
				))}
			</ul>
		</nav>

		<div class="mp-header__actions">
			<button
				class="mp-mood"
				id="mp-mood-toggle"
				type="button"
				aria-pressed="false"
				aria-label="Switch to deep dusk"
				title="Switch mood"
			>
				<svg class="mp-mood__sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="12" cy="12" r="4.5" />
					<path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4" />
				</svg>
				<svg class="mp-mood__moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
				</svg>
			</button>

			<a class="mp-cta mp-cta--sm mp-header__launch" href="#" data-placeholder="app-url">
				Launch
				<span class="mp-cta__ico" aria-hidden="true">
					<svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l5 5-5 5" /></svg>
				</span>
			</a>

			<button class="mp-burger" id="mp-burger" type="button" aria-expanded="false" aria-controls="mp-mobile" aria-label="Open menu">
				<span></span><span></span>
			</button>
		</div>
	</header>
</div>

<!-- Mobile sheet: full glass overlay with a staggered link reveal. -->
<div class="mp-mobile" id="mp-mobile" data-open="false" hidden>
	<nav class="mp-mobile__nav" aria-label="Mobile">
		<ul>
			{nav.map((item, i) => (
				<li style={`--i:${i}`}>
					<a href={item.href} aria-current={activePath === item.href ? 'page' : undefined}>{item.label}</a>
				</li>
			))}
			<li style={`--i:${nav.length}`}>
				<a class="mp-cta mp-cta--lg mp-mobile__cta" href="#" data-placeholder="app-url">Launch MetaProc</a>
			</li>
		</ul>
	</nav>
</div>

<style>
	/* Zero-height sentinel at the very top: an IntersectionObserver watches it so
	   the nav can react to scroll without a scroll listener (perf). */
	.mp-head-sentinel {
		position: absolute;
		top: 0;
		left: 0;
		width: 1px;
		height: 1px;
		pointer-events: none;
	}
	/* Sticky wrapper; the gap above the pill stays click-through. */
	.mp-headwrap {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 0.8rem 1rem 0;
		pointer-events: none;
	}
	.mp-header {
		pointer-events: auto;
		max-width: 73rem;
		margin-inline: auto;
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 0.5rem 0.6rem 0.5rem 1.1rem;
		border-radius: 20px;
		transition: box-shadow .3s var(--mp-ease), border-color .3s ease, background-color .3s ease;
	}
	/* Scrolled state: the island lifts off the content with a deeper shadow and a
	   brighter brand edge (toggled by a top-of-page IntersectionObserver sentinel,
	   never a scroll listener). */
	.mp-header[data-scrolled='true'] {
		border-color: color-mix(in srgb, var(--mp-brand) 30%, var(--mp-edge));
		box-shadow:
			var(--mp-shadow-panel),
			0 18px 50px -30px var(--mp-glow),
			inset 0 1px 0 var(--mp-hi-20);
	}

	.mp-wordmark {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-weight: 800;
		font-size: 1.28rem;
		letter-spacing: -0.03em;
		color: var(--mp-ink);
		text-decoration: none;
	}
	.mp-wordmark:hover { color: var(--mp-ink); }
	.mp-wordmark__tile {
		width: 30px;
		height: 30px;
		flex: none;
		border-radius: 9px;
		display: grid;
		place-items: center;
		background: linear-gradient(160deg, var(--mp-g1), var(--mp-g2));
		box-shadow: 0 0 22px -6px var(--mp-glow), inset 0 1px 0 var(--mp-hi-25);
		transition: transform .3s var(--mp-ease), box-shadow .3s ease;
	}
	.mp-wordmark:hover .mp-wordmark__tile {
		transform: rotate(-6deg) scale(1.05);
		box-shadow: 0 0 28px -6px var(--mp-glow), inset 0 1px 0 var(--mp-hi-30);
	}
	.mp-wordmark__tile svg { width: 19px; height: 19px; display: block; }

	.mp-nav { margin-inline: auto; }
	.mp-nav ul {
		display: flex;
		gap: 0.3rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.mp-nav a {
		color: var(--mp-ink);
		text-decoration: none;
		font-weight: 500;
		font-size: 0.95rem;
		padding: 0.4rem 0.8rem;
		border-radius: 999px;
		transition: color .15s ease, background-color .15s ease;
	}
	.mp-nav a:hover {
		color: var(--mp-link);
		background: color-mix(in srgb, var(--mp-brand) 11%, transparent);
	}
	.mp-nav a[aria-current='page'] {
		color: var(--mp-link);
		background: color-mix(in srgb, var(--mp-brand) 15%, transparent);
	}

	.mp-header__actions {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	/* Mood toggle: icon button on glass. */
	.mp-mood {
		width: 36px;
		height: 36px;
		flex: none;
		display: grid;
		place-items: center;
		cursor: pointer;
		background: transparent;
		border: 1px solid var(--mp-edge);
		border-radius: 11px;
		color: var(--mp-ink);
		padding: 0;
		transition: border-color .2s ease, transform .12s var(--mp-ease), background-color .2s ease;
	}
	.mp-mood:hover {
		border-color: var(--mp-brand);
		background: color-mix(in srgb, var(--mp-brand) 8%, transparent);
	}
	.mp-mood:active { transform: scale(.9); }
	.mp-mood svg { width: 18px; height: 18px; grid-area: 1 / 1; }
	.mp-mood__moon { display: none; }
	:global(html[data-theme='dusk']) .mp-mood__sun { display: none; }
	:global(html[data-theme='dusk']) .mp-mood__moon { display: block; }

	/* Hamburger (mobile only): two bars morph to an X when open. */
	.mp-burger {
		display: none;
		width: 38px;
		height: 36px;
		flex: none;
		position: relative;
		background: transparent;
		border: 1px solid var(--mp-edge);
		border-radius: 11px;
		cursor: pointer;
	}
	.mp-burger span {
		position: absolute;
		left: 9px;
		right: 9px;
		height: 2px;
		border-radius: 2px;
		background: var(--mp-ink);
		transition: transform .3s var(--mp-ease), opacity .2s ease;
	}
	.mp-burger span:nth-child(1) { top: 13px; }
	.mp-burger span:nth-child(2) { bottom: 13px; }
	.mp-burger[aria-expanded='true'] span:nth-child(1) { transform: translateY(4px) rotate(45deg); }
	.mp-burger[aria-expanded='true'] span:nth-child(2) { transform: translateY(-4px) rotate(-45deg); }

	/* Mobile glass sheet. */
	.mp-mobile {
		position: fixed;
		inset: 0;
		z-index: 39;
		display: grid;
		place-items: center;
		background: color-mix(in srgb, var(--mp-canvas) 78%, transparent);
		-webkit-backdrop-filter: blur(22px) saturate(150%);
		backdrop-filter: blur(22px) saturate(150%);
		opacity: 0;
		transition: opacity .32s var(--mp-ease);
	}
	.mp-mobile[data-open='true'] { opacity: 1; }
	.mp-mobile__nav ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1.1rem;
		text-align: center;
	}
	.mp-mobile__nav li {
		opacity: 0;
		transform: translateY(14px);
		transition: opacity .4s var(--mp-ease), transform .4s var(--mp-ease);
		transition-delay: calc(var(--i) * 60ms + 80ms);
	}
	.mp-mobile[data-open='true'] .mp-mobile__nav li { opacity: 1; transform: none; }
	.mp-mobile__nav a {
		color: var(--mp-ink);
		text-decoration: none;
		font-size: 1.6rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	.mp-mobile__nav a[aria-current='page'] { color: var(--mp-link); }
	.mp-mobile__cta { font-size: 1.05rem; margin-top: 0.5rem; }

	@media (max-width: 760px) {
		.mp-nav { display: none; }
		.mp-header__launch { display: none; }
		.mp-burger { display: block; }
	}

	@media (prefers-reduced-motion: reduce) {
		.mp-mobile__nav li { transition: none; }
	}
</style>

<script>
	// Mood toggle: flips [data-theme] on <html>, persists to localStorage.
	const KEY = 'mp-site-mood';
	const btn = document.getElementById('mp-mood-toggle');

	function syncButton(mood: string) {
		if (!btn) return;
		const dusk = mood === 'dusk';
		btn.setAttribute('aria-pressed', dusk ? 'true' : 'false');
		btn.setAttribute('aria-label', dusk ? 'Switch to warm light' : 'Switch to deep dusk');
	}

	if (btn) {
		syncButton(document.documentElement.getAttribute('data-theme') === 'dusk' ? 'dusk' : 'light');
		btn.addEventListener('click', () => {
			const next =
				document.documentElement.getAttribute('data-theme') === 'dusk' ? 'light' : 'dusk';
			document.documentElement.setAttribute('data-theme', next);
			try {
				localStorage.setItem(KEY, next);
			} catch (e) {
				/* storage unavailable, mood still flips for this page */
			}
			syncButton(next);
		});
	}

	// Mobile sheet: open/close with the hamburger, lock scroll, ESC to close.
	const burger = document.getElementById('mp-burger');
	const sheet = document.getElementById('mp-mobile');

	function setSheet(open: boolean) {
		if (!burger || !sheet) return;
		burger.setAttribute('aria-expanded', open ? 'true' : 'false');
		burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
		document.body.style.overflow = open ? 'hidden' : '';
		if (open) {
			sheet.hidden = false;
			requestAnimationFrame(() => sheet.setAttribute('data-open', 'true'));
		} else {
			sheet.setAttribute('data-open', 'false');
			window.setTimeout(() => {
				if (sheet.getAttribute('data-open') === 'false') sheet.hidden = true;
			}, 340);
		}
	}

	if (burger && sheet) {
		burger.addEventListener('click', () =>
			setSheet(burger.getAttribute('aria-expanded') !== 'true'),
		);
		sheet.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setSheet(false)));
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') setSheet(false);
		});
	}

	// Scroll-aware nav: a top-of-page sentinel toggles the island's lifted state
	// when it leaves the viewport. IntersectionObserver, never a scroll listener.
	const sentinel = document.querySelector('.mp-head-sentinel');
	const island = document.querySelector('.mp-header');
	if (sentinel && island && 'IntersectionObserver' in window) {
		const io = new IntersectionObserver(
			([entry]) => island.setAttribute('data-scrolled', entry.isIntersecting ? 'false' : 'true'),
			{ threshold: 0 },
		);
		io.observe(sentinel);
	}
</script>
